# Copy this file to ".env" and fill in your own values.
# Docker Compose reads ".env" automatically from the project directory.

# Hugging Face token (required)
# 1. Create a token at https://huggingface.co/settings/tokens
# 2. Accept the license for the model you plan to run (see README hardware profiles)
HF_TOKEN=hf_your_token_here

# Model and runtime tuning (defaults = 12B QAT strong local setup)
GEMMA_MODEL=google/gemma-4-12B-it-qat-w4a16-ct
MAX_MODEL_LEN=4096
GPU_MEMORY_UTIL=0.90
LIMIT_MM_PER_PROMPT={"image": 4}

# Smaller-GPU examples (uncomment one profile and accept its HF license):
# GEMMA_MODEL=google/gemma-4-E4B-it-qat-w4a16-ct
# MAX_MODEL_LEN=8192
# GPU_MEMORY_UTIL=0.90
# LIMIT_MM_PER_PROMPT={"image": 4}

# GEMMA_MODEL=google/gemma-4-E2B-it-qat-w4a16-ct
# MAX_MODEL_LEN=8192
# GPU_MEMORY_UTIL=0.85
# LIMIT_MM_PER_PROMPT={"image": 2}
